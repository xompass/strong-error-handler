{
  "name": "@xompass/error-handler",
  "description": "Error handler for use in development and production environments.",
  "license": "MIT",
  "version": "5.0.29",
  "author": "IBM Corp.",
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/xompass/strong-error-handler"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "views",
    "README.md",
    "LICENSE.md"
  ],
  "scripts": {
    "build": "tsdown",
    "fmt": "oxfmt .",
    "lint": "oxlint src test",
    "prepack": "npm run build",
    "prepublishOnly": "npm run typecheck && npm run lint && npm test",
    "prepare": "npm run build",
    "test": "npm run build && vitest run",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "accepts": "^1.3.8",
    "debug": "^4.4.3",
    "handlebars": "^4.7.9",
    "js2xmlparser": "^5.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "supertest": "^7.2.2",
    "tsdown": "^0.21.7",
    "typescript": "6.0.2",
    "vitest": "^4.1.2"
  }
}
